# Production environment template for the healthCare-monitor frontend.
#
# This is a *template*, deliberately named `.env.production.example` rather than
# `.env.production`: Next.js auto-loads `.env.production` during `next build` and
# inlines every `NEXT_PUBLIC_*` value into the bundle. On Vercel you set these in
# the project's Environment Variables (Production scope) instead, so the build
# picks up the real values without a committed file baking in a placeholder.
#
# See docs/DEPLOY_PRODUCTION_FRONTEND.md.

# Base URL of the deployed backend API, including the /api prefix.
# Example (Render): https://caretrace-backend.onrender.com/api
NEXT_PUBLIC_API_BASE_URL=https://your-backend-host/api

# Dev-only observability panel. Keep 0 in production; set to 1 only to opt in to
# the panel on a deployed instance for debugging.
NEXT_PUBLIC_OBSERVABILITY=0
