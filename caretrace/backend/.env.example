# healthCare-monitor backend — local environment
# Copy to `.env` and adjust as needed. Every value below has a sensible default
# in app/core/config.py, so the app runs with an empty .env for a local demo.

# --- Database ---------------------------------------------------------------
# Default: a local SQLite file — zero external infrastructure, ideal for demos.
# Tables are auto-created on startup for SQLite; seed with:
#   uv run python -m app.seed_demo
DATABASE_URL=sqlite:///./caretrace_demo.db
#
# For a production-like setup, point at Postgres instead and manage schema with
# Alembic (`uv run alembic upgrade head`). The models are dialect-portable, so
# the same code runs on either engine:
# DATABASE_URL=postgresql+psycopg://healthcare:healthcare@localhost:5432/healthcare

# --- CORS -------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API (Next.js dev = :3000).
CORS_ORIGINS=http://localhost:3000

# --- Provider selection -----------------------------------------------------
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# --- OpenAI provider --------------------------------------------------------
# Only required if you process live transcripts with OpenAI. The seeded demo
# and the dashboard do not need a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama provider (local, optional) --------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
