# CareTrace backend — local environment (Phase 1)

# Postgres connection (SQLAlchemy + psycopg v3 driver)
DATABASE_URL=postgresql+psycopg://caretrace:caretrace@localhost:5432/caretrace

# Provider defaults (reserved for later phases; unused in Phase 1)
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# The following are intentionally NOT used in Phase 1.
# They are documented in docs/DEPLOYMENT.md and will be wired in later phases:
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
