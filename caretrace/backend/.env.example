# CareTrace backend — local environment

# Postgres connection (SQLAlchemy + psycopg v3 driver)
DATABASE_URL=postgresql+psycopg://caretrace:caretrace@localhost:5432/caretrace

# Default provider selection
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama provider (local; optional if only using OpenAI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
